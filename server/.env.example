# ─── Modulo Formulario · Backend ──────────────────────────────────────
PORT=4002
CORS_ORIGINS=*
JSON_BODY_LIMIT=1mb

# ─── La Mundial (catalogos INMA + valrep) ──────────────────────────────
# Si el cliente no es La Mundial, este modulo puede operar con catalogos
# locales. En ese caso deja LAMUNDIAL_BASE_URL vacio.
LAMUNDIAL_BASE_URL=https://qaapisys2000.lamundialdeseguros.com
LAMUNDIAL_APIKEY=
LAMUNDIAL_PRODUCTOR=80080
LAMUNDIAL_CUSUARIO=4
LAMUNDIAL_RAMO=18
LAMUNDIAL_TIMEOUT_MS=30000
