# ─── Modulo Formulario · Backend ──────────────────────────────────────
PORT=4002
CORS_ORIGINS=*
JSON_BODY_LIMIT=1mb

# ─── Multi-tenant (Nexus) ─────────────────────────────────────────────
# Si true, todas las rutas /api/catalogo y /api/valrep requieren nexus_token valido.
NEXUS_AUTH_ENABLED=true
# Mismo secret configurado en nexus-api (TENANT_TOKEN_SECRET).
TENANT_TOKEN_SECRET=
# Id del submodulo Formulario en la BD de nexus.
NEXUS_EXPECTED_SUBMODULO_ID=18

# ─── La Mundial (catalogos INMA + valrep state/city) ──────────────────
# Expone POST /api/v1/valrep/state y /api/v1/valrep/city (documentados).
# NO expone /api/v1/valrep/getLists (SEXO/EDOCIVIL/etc.) — ese endpoint
# no existe en la API externa de La Mundial (ni QA ni producción).
LAMUNDIAL_BASE_URL=https://qaapisys2000.lamundialdeseguros.com
LAMUNDIAL_APIKEY=
LAMUNDIAL_PRODUCTOR=80080
LAMUNDIAL_CUSUARIO=4
LAMUNDIAL_RAMO=18
LAMUNDIAL_TIMEOUT_MS=30000

# ─── sysip-nest-api (Sis2000 — fuente para getLists) ───────────────────
# Provee POST /api/v1/valrep/getLists con datos reales de Sis2000:
#   PARENTESCOS → tabla maparent
#   SEXO / EDOCIVIL / FRECUENCIAS / MATIPCANAL → constantes regulatorias
# En producción apuntar a la IP/puerto donde corra sysip-nest-api.
SYSIP_NEST_URL=http://localhost:3001
